{
    "version": 2,
    "builds": [
        { "src": "api/server.js", "use": "@vercel/node" },
        { "src": "public/frontend/**", "use": "@vercel/static" },
        { "src": "public/**", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/server.js" },
        { "src": "/public/(.*)", "dest": "/public/$1" },
        { "src": "/(.*)", "dest": "/public/frontend/$1" }
    ]
}